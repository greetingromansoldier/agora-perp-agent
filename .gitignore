# Python
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
**/.pytest_cache/
**/*.egg-info/
**/dist/
**/build/

# Rust
**/target/

# uv
**/.python-version

# Editors
.idea/
.vscode/
*.swp
.DS_Store

# Secrets — track .env.example, never the real .env
.env
.env.local
**/wallet_keys/
**/*.privkey
**/*.pem
circle_ciphertext.txt
circle_recovery.txt

# Runtime audit store — local sqlite, can grow large; not source tree.
# (`dashboard/data/snapshot.json` IS committed — that's what GH Pages
# serves.)
audit.sqlite
audit.sqlite-shm
audit.sqlite-wal

# Local config overrides
configs/*.local.json

# Generated data (top-level only — does NOT match dashboard/data/).
/data/
!/data/.gitkeep
/output/
!/output/.gitkeep
