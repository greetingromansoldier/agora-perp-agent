# Copy to .env (gitignored) and fill in real values. Never commit a
# populated .env to the repo.

# LLM (Gemini for the decision agent).
# Get a key at aistudio.google.com — free tier covers paper trading.
GEMINI_API_KEY=

# Circle Developer-Controlled Wallets on Arc Testnet.
# Step 1: console.circle.com → API Keys → create a 'Test API Key'.
# Step 2: paste it below as CIRCLE_API_KEY.
# Step 3: run `python scripts/circle_setup.py` — it generates the
# entity secret, registers its ciphertext, and provisions a wallet.
# Steps 4-7 below are filled by that script.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=
